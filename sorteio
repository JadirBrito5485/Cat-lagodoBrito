<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sorteio R$300 - Rio Negrinho Shop</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css"/>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css"/>
    
    <style>
        :root {
            --azul-brito: #004aad;
            --azul-claro: #00a8ff;
            --tiktok: #000000;
            --shopee-orange: #ee4d2d;
            --bg: #f8f9fa;
        }

        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); margin: 0; }
        .nav-header { padding: 15px; background: #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.1); position: sticky; top: 0; z-index: 1000; }
        .btn-loja { text-decoration: none; color: var(--azul-brito); font-weight: bold; font-size: 14px; display: flex; align-items: center; gap: 8px; }

        .container { max-width: 600px; margin: 0 auto; padding: 20px; }

        .banner-box { background: #fff; border-radius: 20px 20px 0 0; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
        .banner-box img { width: 100%; height: auto; display: block; }
        
        .header-content { padding: 20px; text-align: center; }
        .modern-title { font-size: 26px; font-weight: 900; text-transform: uppercase; color: var(--azul-brito); margin: 0; }
        .data-info { display: block; margin-top: 5px; font-weight: bold; color: #d63031; }

        .card-form { background: #fff; padding: 25px; border-radius: 0 0 20px 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 20px; }
        
        .input-group { margin-bottom: 15px; }
        label { display: block; font-size: 12px; font-weight: bold; color: var(--azul-brito); margin-bottom: 5px; }
        input { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; font-size: 16px; }

        .btn-enviar { width: 100%; padding: 18px; background: var(--azul-brito); color: white; border: none; border-radius: 10px; font-size: 18px; font-weight: bold; cursor: pointer; transition: 0.3s; }
        .btn-enviar:hover { background: var(--azul-claro); }

        /* MENU DE TRANSPARÊNCIA (ACORDEON) */
        .transparency-menu { background: #fff; border-radius: 15px; overflow: hidden; margin-bottom: 30px; border: 1px solid #eee; }
        .menu-item { border-bottom: 1px solid #eee; }
        .menu-header { padding: 15px; background: #f9f9f9; cursor: pointer; display: flex; justify-content: space-between; font-weight: bold; font-size: 14px; color: #444; }
        .menu-content { padding: 15px; display: none; font-size: 13px; line-height: 1.6; color: #666; }
        .menu-content b { color: #333; }

        /* VITRINE */
        .vitrine-section { margin-top: 40px; padding-bottom: 50px; }
        .prod-item { background: #fff; margin: 10px; border-radius: 12px; border: 1px solid #eee; cursor: pointer; text-align: center; }
        .prod-item img { width: 100%; aspect-ratio: 1/1; object-fit: cover; }
        .prod-price { color: var(--shopee-orange); font-weight: bold; padding: 10px; display: block; }
    </style>
</head>
<body>

    <div class="nav-header">
        <a href="https://rionegrinho.shop" class="btn-loja"><i class="fas fa-chevron-left"></i> RIONEGRINHO.SHOP</a>
    </div>

    <div class="container">
        <div class="banner-box">
            <img src="https://investidorsardinha.r7.com/wp-content/uploads/2024/01/como-ganhar-r-300-por-mes-sem-trabalhar.png" alt="Sorteio">
            <div class="header-content">
                <h1 class="modern-title">Sorteio de R$ 300,00</h1>
                <span class="data-info">SORTEIO: 25/05/2026 ÀS 12:00h</span>
            </div>
        </div>

        <div class="card-form">
            <form action="https://formsubmit.co/brito302022@gmail.com" method="POST" id="mainForm">
                <input type="hidden" name="_next" value="https://rionegrinho.shop">
                <input type="hidden" name="_captcha" value="false">

                <div class="input-group">
                    <label>Nome Completo</label>
                    <input type="text" name="Nome" id="f_nome" required>
                </div>
                <div class="input-group">
                    <label>CPF (Para conferência do ganhador)</label>
                    <input type="text" name="CPF" id="f_cpf" placeholder="000.000.000-00" required>
                </div>
                <div class="input-group">
                    <label>Seu WhatsApp</label>
                    <input type="tel" name="WhatsApp" id="f_whats" placeholder="(47) 9..." required>
                </div>
                <div class="input-group">
                    <label>WhatsApp de um amigo (Rio Negrinho)</label>
                    <input type="tel" name="WhatsApp_Amigo" id="f_amigo" required>
                </div>

                <p style="font-size: 11px; color: #999; text-align: center;">
                    Ao clicar em participar, você concorda com nosso regulamento e política de privacidade de dados.
                </p>
                <button type="submit" class="btn-enviar">PARTICIPAR DO SORTEIO</button>
            </form>
        </div>

        <div class="transparency-menu">
            <div class="menu-item">
                <div class="menu-header" onclick="toggleMenu(0)">
                    REGULAMENTO DO SORTEIO <i class="fas fa-chevron-down"></i>
                </div>
                <div class="menu-content" id="m0">
                    <b>1. Participação:</b> Sorteio gratuito e exclusivo para residentes de Rio Negrinho - SC. <br>
                    <b>2. Como Participar:</b> Preencher todos os campos do formulário oficial no site rionegrinho.shop.<br>
                    <b>3. O Prêmio:</b> Valor de R$ 300,00 pago via PIX ou em mãos conforme escolha do organizador.<br>
                    <b>4. Data e Local:</b> O sorteio ocorrerá dia 25/05/2026 às 12h, anunciado ao vivo no TikTok <b>@falabritooficial</b>.<br>
                    <b>5. Entrega:</b> O ganhador será contatado via WhatsApp. Caso não responda em 24h, um novo sorteio será realizado.
                </div>
            </div>

            <div class="menu-item">
                <div class="menu-header" onclick="toggleMenu(1)">
                    PRIVACIDADE E DADOS (LGPD) <i class="fas fa-chevron-down"></i>
                </div>
                <div class="menu-content" id="m1">
                    <b>Coleta de Dados:</b> Coletamos seu Nome, CPF e WhatsApp exclusivamente para identificar o ganhador e evitar fraudes (várias inscrições da mesma pessoa).<br>
                    <b>Segurança:</b> Seus dados não serão vendidos ou compartilhados com terceiros. <br>
                    <b>Armazenamento:</b> Os dados serão excluídos de nossa base 30 dias após a entrega do prêmio.
                </div>
            </div>

            <div class="menu-item">
                <div class="menu-header" onclick="toggleMenu(2)">
                    DÚVIDAS E SUPORTE <i class="fas fa-chevron-down"></i>
                </div>
                <div class="menu-content" id="m2">
                    Para dúvidas sobre o sorteio, entre em contato via WhatsApp oficial da Rio Negrinho Shop ou através do Portal Fala Brito no TikTok.
                </div>
            </div>
        </div>

        <div class="vitrine-section">
            <h3 style="text-align:center; font-size: 14px; color: #888;">VISITE NOSSA LOJA</h3>
            <div id="carousel-prods"></div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getDatabase, ref, onValue, push } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js";

        const firebaseConfig = {
            apiKey: "AIzaSyCf6_DCNSh4a3IiOtTv5Uf_N8YaxQtBczw",
            authDomain: "loja-a33e1.firebaseapp.com",
            databaseURL: "https://loja-a33e1-default-rtdb.firebaseio.com",
            projectId: "loja-a33e1",
            storageBucket: "loja-a33e1.firebasestorage.app",
            messagingSenderId: "304798626706",
            appId: "1:304798626706:web:23a0672e6a98ae432c474b"
        };

        const app = initializeApp(firebaseConfig);
        const db = getDatabase(app);

        // Funções do Menu
        window.toggleMenu = (id) => {
            $(`#m${id}`).slideToggle();
        };

        // Carregar Vitrine
        onValue(ref(db, 'produtos'), (snap) => {
            const data = snap.val();
            const carousel = $('#carousel-prods');
            if (carousel.hasClass('slick-initialized')) carousel.slick('unslick');
            carousel.empty();
            for (let id in data) {
                if(data[id].stock > 0) {
                    carousel.append(`
                        <div class="prod-item" onclick="window.location.href='https://rionegrinho.shop'">
                            <img src="${data[id].img}">
                            <span class="prod-price">R$ ${parseFloat(data[id].price).toFixed(2)}</span>
                        </div>
                    `);
                }
            }
            carousel.slick({ autoplay: true, autoplaySpeed: 2000, slidesToShow: 3, arrows: false, dots: true });
        });

        // Backup Firebase
        document.getElementById('mainForm').onsubmit = function() {
            const data = {
                nome: document.getElementById('f_nome').value,
                cpf: document.getElementById('f_cpf').value,
                whatsapp: document.getElementById('f_whats').value,
                amigo: document.getElementById('f_amigo').value,
                data: new Date().toLocaleString()
            };
            push(ref(db, 'sorteio_registros'), data);
        };
    </script>
</body>
</html>
